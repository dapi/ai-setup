<!DOCTYPE html>
<html>
  <head>
    <title><%= t("admin.layout.title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <header>
      <nav>
        <%= link_to t("admin.layout.hotels"), admin_hotels_path %> |
        <%= link_to t("admin.layout.staff"), admin_staff_index_path %> |
        <%= link_to t("admin.layout.tickets"), admin_tickets_path %>
      </nav>
    </header>

    <main>
      <% if flash[:notice].present? %>
        <p><%= flash[:notice] %></p>
      <% end %>

      <% if flash[:alert].present? %>
        <p><%= flash[:alert] %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
