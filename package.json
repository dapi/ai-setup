{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development bun --hot src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "compile": "tsc --noEmit",
    "serve": "NODE_ENV=production bun src/index.ts",
    "lint": "oxlint --fix && oxfmt --write",
    "lint:ci": "oxlint && oxfmt --check",
    "test": "bun run build && bun test && bunx playwright test",
    "test:api": "NODE_ENV=development bun test",
    "test:e2e": "NODE_ENV=development bunx playwright test"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "typescript": "^6.0.2"
  }
}
